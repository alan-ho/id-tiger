# Autodesk NPM Artifactory Configuration
# This file configures npm to use Autodesk's internal Artifactory as the registry
# instead of the public npm registry (registry.npmjs.org)
#
# Why this is needed:
# - Anonymous access to Autodesk's Artifactory NPM repositories has been disabled
# - Access to public NPM registry is restricted at firewall level for internal networks
# - All npm install commands must authenticate through Autodesk Artifactory
#
# Authentication:
# - Local development: Run `npm login --registry <registry-url> --auth-type legacy`
#   After login, auth tokens are stored in ~/.npmrc (user-specific)
# - CI/CD: CloudOS v3 handles npm/serverless installation and authentication automatically
#
# Registry: autodesk-npm-virtual
# This virtual repository aggregates both internal Autodesk packages and proxies public npm packages
registry=https://npm.autodesk.com/artifactory/api/npm/autodesk-npm-virtual/

# @weave-mui/avatar has a peer dep on @mui/material ^5.x and has not yet released
# a v6-compatible version. Allow install to proceed until an upstream fix ships.
legacy-peer-deps=true

# Note: Authentication tokens:
# - For local dev: After running `npm login`, tokens are stored in ~/.npmrc (user-specific)
# - For CI/CD: CloudOS v3 handles authentication automatically, this file is not used
